# =============================================================
# OpsAgent 环境变量样例
# 复制此文件为 .env 后填入真实值；.env 已在 .gitignore 中
# 严禁把真实 Key 写进 .env.example、提交到 git、贴到任何聊天/文档
# =============================================================

# ---------- 应用基础 ----------
APP_ENV=dev                                # dev / prod
APP_LOG_LEVEL=INFO                         # DEBUG / INFO / WARNING
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- 模型 API（按需填入；至少填一家） ----------
# DeepSeek 官方：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里云百炼（Qwen 系列，OpenAI 兼容入口）：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- 模型路由策略（可在 LiteLLM yaml 覆盖） ----------
# 主链路决策类节点：Qwen3.7-Max（百炼免费额度 200 次/日 + 100w token）
MODEL_PLAN=qwen3.7-max
MODEL_REFLECT=qwen3.7-max
MODEL_ANSWER=qwen3.7-max
# 异步小任务（Profile Updater 等）走更便宜的 qwen-turbo
MODEL_UPDATER=qwen-turbo
# 备份模型（主模型限流/失败时降级到 DeepSeek，避开同家限流）
MODEL_FALLBACK=deepseek-chat

# ---------- 上下文 / 记忆参数 ----------
# 触发压缩的上下文占用比例（详见 docs/架构设计.md 第四节 记忆系统）
MEMORY_COMPACT_TOKEN_RATIO=0.7
MEMORY_COMPACT_ROUND_COUNT=8
MAX_AGENT_ITERATIONS=5
# 模型上下文窗口兜底值（litellm 取不到自定义别名模型的 max_tokens 时回退此值算压缩阈值）
MEMORY_MAX_CONTEXT_TOKENS=32768
# 装配上下文时保留的最近完整轮数（更早的走压缩摘要）
MEMORY_KEEP_RECENT_TURNS=3
# 一级摘要累计达此条数触发递归压缩（多摘要合并为更高层）
MEMORY_SUMMARY_MERGE_COUNT=4
# 装配画像时按 query 召回的历史故障模式条数
MEMORY_FAULT_PATTERN_TOP_N=3

# ---------- W2 混合检索 RAG ----------
# embedding / rerank 走 FlagEmbedding 本地推理（不经 litellm）
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# 两路召回各取 top_n，融合后送 rerank 的候选池上限
RETRIEVAL_RECALL_TOP_N=50
# RRF 融合常数 k（越大越平滑，业界惯例 60）
RETRIEVAL_RRF_K=60
# 知识库 chunk 表名（记忆系统的 profile/episodic 表与之同库，靠表名隔离）
KB_TABLE=kb_chunks
# bm25s 离线索引落盘目录（已 gitignore）
BM25_INDEX_DIR=bm25_index

# ---------- 工具治理（W3 Tool 抽象层默认值，可被单工具注册时覆盖） ----------
# 单次工具调用超时（秒）；超时仅"停止等待"，同步工具的孤儿线程无法强杀
TOOL_TIMEOUT_S=10.0
# 失败后额外重试次数（不含首次）；入参校验失败不重试，且当前为立即重试无退避
TOOL_MAX_RETRIES=1
# 输出截断：单个字符串字段最大长度 / 单个列表最多保留条数（防大块文本污染上下文）
TOOL_MAX_OUTPUT_CHARS=2000
TOOL_MAX_LIST_ITEMS=30
# MCP 客户端桥单次跨进程调用的安全上限（秒）；真正的单工具超时由 Tool.timeout_s 控制
MCP_CALL_TIMEOUT_S=90.0

# ---------- Postgres + pgvector ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opsagent
POSTGRES_USER=opsagent
POSTGRES_PASSWORD=change-me-in-real-env

# 拼装后的 SQLAlchemy 连接串（应用代码里用这个）
DATABASE_URL=postgresql+psycopg://opsagent:change-me-in-real-env@localhost:5432/opsagent

# ---------- Langfuse 可观测（启动时自动探测，优先本地 → 降级 Cloud）----------
# 本地自托管（make langfuse-up 后自动可用，无需手动切换）
LANGFUSE_LOCAL_HOST=http://localhost:3000
LANGFUSE_LOCAL_PUBLIC_KEY=pk-lf-local-opsagent
LANGFUSE_LOCAL_SECRET_KEY=sk-lf-local-opsagent
# Cloud 兜底（本地不可用时自动降级到这里）
# 注册：https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---------- 数据合成种子（保证可复现） ----------
SYNTH_SEED=42

# ---------- 真实环境日志接入（可选，火山引擎 TLS + TOS）----------
# 说明：默认关闭；仅当需要把 Agent 接到真实生产/uat 日志（火山引擎 TLS 日志服务）时才配置。
#      关闭时工具静默走本地合成数据，不影响主流程。详见 docs/使用说明.md「真实环境日志接入」。
# 开关：置 1 才启用云端 fallback（缺任一凭证/topic 时自动降级为软失败，仍走本地）
AGENT_ENABLE_TLS_FALLBACK=0
# 火山引擎访问凭证（控制台申请，勿提交真实值）
TOS_ACCESS_KEY=your-volc-access-key
TOS_SECRET_KEY=your-volc-secret-key
TOS_ENDPOINT=tos-cn-<region>.volces.com
TOS_REGION=cn-<region>
TOS_BUCKET=your-bucket
# TLS 日志服务端点与查询 topic
TLS_ENDPOINT=https://tls-cn-<region>.volces.com
TLS_REGION=cn-<region>
# 生产/测试环境各自的日志主题 ID（控制台 → 日志服务 → 主题）
TLS_PROD_TOPIC_ID=your-prod-topic-id
TLS_TOPIC_ID=your-topic-id
